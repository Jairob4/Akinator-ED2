<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.akinator.controlador.JuegoController"
      styleClass="root-pane"
      alignment="TOP_CENTER"
      spacing="0"
      prefWidth="700" prefHeight="520">

    <!-- HEADER -->
    <HBox styleClass="header-juego" alignment="CENTER_LEFT" spacing="16">
        <Button text="← Menú" styleClass="btn-volver" onAction="#onVolverMenu"/>
        <Label text="🧞 Akinator" styleClass="titulo-juego"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblPreguntaNum" text="Pregunta 1" styleClass="pregunta-contador"/>
    </HBox>

    <!-- ÁREA PRINCIPAL -->
    <VBox alignment="CENTER" spacing="24" VBox.vgrow="ALWAYS" styleClass="area-juego">

        <!-- Burbuja de pregunta -->
        <VBox styleClass="burbuja-pregunta" alignment="CENTER">
            <Label fx:id="lblPregunta"
                   text="Piensa en un personaje..."
                   styleClass="texto-pregunta"
                   wrapText="true"
                   maxWidth="500"
                   alignment="CENTER"/>
        </VBox>

        <!-- Botones de respuesta (visibles durante preguntas) -->
        <HBox fx:id="panelRespuestas" alignment="CENTER" spacing="24">
            <Button text="✅  SÍ"
                    styleClass="btn-si"
                    onAction="#onSi"
                    prefWidth="160" prefHeight="56"/>
            <Button text="❌  NO"
                    styleClass="btn-no"
                    onAction="#onNo"
                    prefWidth="160" prefHeight="56"/>
        </HBox>

        <!-- Panel cuando Akinator cree saber la respuesta -->
        <VBox fx:id="panelAdivinanza" alignment="CENTER" spacing="16"
              visible="false" managed="false">
            <Label text="¡Creo que sé quién es!" styleClass="label-adivinanza-titulo"/>
            <Label fx:id="lblPersonajeAdivinado" text=""
                   styleClass="label-personaje-adivinado"/>
            <Label text="¿Es tu personaje?" styleClass="label-confirmacion"/>
            <HBox alignment="CENTER" spacing="20">
                <Button text="✅  ¡Sí, adivinaste!"
                        styleClass="btn-si"
                        onAction="#onAcertó"
                        prefWidth="180" prefHeight="50"/>
                <Button text="❌  No, fallaste"
                        styleClass="btn-no"
                        onAction="#onFalló"
                        prefWidth="180" prefHeight="50"/>
            </HBox>
        </VBox>

        <!-- Panel de aprendizaje (cuando falla) -->
        <VBox fx:id="panelAprendizaje" alignment="CENTER" spacing="14"
              visible="false" managed="false" styleClass="panel-aprendizaje">
            <Label text="¡Voy a aprender! ¿En quién pensabas?" styleClass="label-aprender-titulo"/>
            <TextField fx:id="txtNuevoPersonaje"
                       promptText="Nombre del personaje"
                       styleClass="input-campo"
                       maxWidth="380"/>
            <Label text="¿Qué pregunta lo diferencia del personaje que yo dije?"
                   styleClass="label-aprender-sub" wrapText="true" maxWidth="420"
                   alignment="CENTER"/>
            <TextField fx:id="txtNuevaPregunta"
                       promptText="Escribe una pregunta (ej: ¿Es deportista?)"
                       styleClass="input-campo"
                       maxWidth="380"/>
            <Label text="Para tu personaje, esa pregunta es:" styleClass="label-aprender-sub"/>
            <HBox alignment="CENTER" spacing="20">
                <Button text="✅  SÍ"
                        styleClass="btn-si"
                        onAction="#onAprender_Si"
                        prefWidth="140" prefHeight="46"/>
                <Button text="❌  NO"
                        styleClass="btn-no"
                        onAction="#onAprender_No"
                        prefWidth="140" prefHeight="46"/>
            </HBox>
        </VBox>

    </VBox>

    <!-- FOOTER con métricas en tiempo real -->
    <HBox styleClass="footer-juego" alignment="CENTER" spacing="30">
        <Label fx:id="lblMetricaPreguntas" text="Preguntas: 0" styleClass="metrica-label"/>
        <Label fx:id="lblMetricaTiempo"    text="Tiempo: 0ms"  styleClass="metrica-label"/>
        <Label fx:id="lblMetricaMemoria"   text="Memo: 0"      styleClass="metrica-label"/>
        <Button text="↩ Retroceder" styleClass="btn-retroceder"
                onAction="#onRetroceder" fx:id="btnRetroceder"/>
    </HBox>

</VBox>